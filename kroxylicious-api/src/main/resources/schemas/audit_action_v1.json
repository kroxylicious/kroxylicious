{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "http://schema.kroxylicious/io/audit-action.yaml",
  "description": "The schema for audit actions",
  "type": "object",
  "properties": {
    "time": {
      "description": "When the event happened",
      "type": "string",
      "format": "date-time"
    },
    "action": {
      "description": "What happened. Actions within the runtime use a plain CamelCase identifier. Actions from plugins should be package-prefixed.",
      "type": "string",
      "pattern": "^([a-z0-9_]+[.])*[A-Z][a-zA-Z0-9_]*$"
    },
    "status": {
      "description": "Null of the action was a success. Otherwise a machine readable identifier, error or status code describing the failure.",
      "type": [
        "string",
        "null"
      ],
      "pattern": "^([a-zA-Z0-9_]+[.])*[a-zA-Z0-9_]+$"
    },
    "reason": {
      "description": "Null of the action was a success. Otherwise a human readable reason for the failure.",
      "type": [
        "string",
        "null"
      ]
    },
    "actor": {
      "description": "Who caused the action to be taken.",
      "type": "object",
      "properties": {
        "srcAddr": {
          "description": "The client IP address",
          "type": "string"
        },
        "session": {
          "description": "The sessionId",
          "type": "string",
          "format": "uuid"
        },
        "principals": {
          "description": "The principals of the authenticated client, or null if the client is not authenticated.",
          "type": ["array", "null"],
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "objectRef": {
      "description": "Identifies the object which the action was performed on",
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    },
    "context": {
      "description": "Additional context",
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
